{
  "name": "nti-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:start": "docker compose -f docker-compose.dev.yml up -d",
    "dev:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f backend database",
    "prisma:generate": "docker compose -f docker-compose.dev.yml run --rm backend npx prisma generate",
    "prisma:migrate:dev": "docker compose -f docker-compose.dev.yml run --rm backend npx prisma migrate dev",
    "prisma:reset": "docker compose -f docker-compose.dev.yml run --rm backend npx prisma migrate reset --force",
    "db:start": "docker compose -f docker-compose.dev.yml up -d database",
    "db:stop": "docker compose -f docker-compose.dev.yml stop database",
    "lint": "eslint . --ext .ts --max-warnings=20",
    "lint:fix": "eslint . --ext .ts --fix && prettier --write .",
    "type-check": "tsc --noEmit",
    "vitest": "vitest run",
    "vitest:watch": "vitest watch",
    "check": "npm run lint && npm run type-check && npm run vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
